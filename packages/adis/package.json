{
  "name": "@czagents/adis",
  "version": "0.1.1",
  "description": "MCP server for ADIS — Czech VAT-payer reliability check (nespolehlivý plátce DPH) via the official MFČR SOAP service. Returns reliability status, published bank accounts, subject name + address.",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "cz-agents-adis": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "adis",
    "dph",
    "vat",
    "czech",
    "kyc",
    "claude"
  ],
  "license": "MIT",
  "author": "Martin Havel <martin.havel@gmail.com>",
  "homepage": "https://cz-agents.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/martinhavel/cz-agents-mcp.git",
    "directory": "packages/adis"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/index.js",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "start:http": "node dist/http.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@czagents/shared": "^0.1.7",
    "@modelcontextprotocol/sdk": "^1.10.0",
    "fast-xml-parser": "^5.7.2",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@vitest/coverage-v8": "^4.1.4",
    "tsx": "^4.7.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.4"
  },
  "mcpName": "dev.cz-agents/adis"
}
