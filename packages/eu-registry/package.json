{
  "name": "@czagents/eu-registry",
  "version": "0.1.1",
  "description": "MCP server for EU business registries — GB (Companies House), SK (ORSR), PL (KRS), NL (GLEIF/LEI), DE (GLEIF/LEI), FR (SIRENE)",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "cz-agents-eu-registry": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/index.js",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "start:http": "node dist/http.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@czagents/shared": "^0.1.9",
    "@modelcontextprotocol/sdk": "^1.10.0",
    "better-sqlite3": "^11.5.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.4"
  },
  "mcpName": "dev.cz-agents/eu-registry",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  }
}
