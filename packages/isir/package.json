{
  "name": "@czagents/isir",
  "version": "0.2.2",
  "description": "MCP server for ISIR (Czech Insolvency Register) — IČO and person insolvency check via official SOAP web services (PublicWS event feed + CuzkWS for lookups).",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "cz-agents-isir": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "isir",
    "czech",
    "insolvency",
    "kyc",
    "claude"
  ],
  "license": "MIT",
  "author": "Martin Havel <martin.havel@gmail.com>",
  "homepage": "https://cz-agents.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/martinhavel/cz-agents-mcp.git",
    "directory": "packages/isir"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "start:http": "node dist/http.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@czagents/shared": "^0.1.7",
    "@modelcontextprotocol/sdk": "^1.10.0",
    "fast-xml-parser": "^5.7.2",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@vitest/coverage-v8": "^4.1.4",
    "tsx": "^4.7.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.4"
  },
  "mcpName": "dev.cz-agents/isir"
}
